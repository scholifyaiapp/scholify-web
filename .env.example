# Scholify — environment variables
# Copy this file to ".env" and fill in your real credentials.
# Without Supabase vars the app runs in local DEMO mode (auth still works).

# ── Supabase ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Paddle Billing (web checkout) ──
# Without these the pricing buttons show a "coming soon" notice.
VITE_PADDLE_TOKEN=your_paddle_client_token
VITE_PADDLE_BEGINNER_MONTHLY=pri_xxx
VITE_PADDLE_PRO_MONTHLY=pri_xxx
VITE_PADDLE_ANNUAL_PRO=pri_xxx
