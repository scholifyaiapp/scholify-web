# Scholify — environment variables
# Copy this file to ".env" and fill in real values.
#
# SECURITY: only VITE_-prefixed vars are exposed to the browser.
# AI keys must NEVER have a VITE_ prefix — they are read server-side
# by the /api serverless functions only.

# ── Supabase ──
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── AI (server-side only — never VITE_ prefix) ──
# Charles (the AI tutor/examiner persona) picks a provider automatically:
# ANTHROPIC_API_KEY is preferred if set, OPENAI_API_KEY is the fallback;
# with neither set, every AI action degrades to a deterministic fallback
# instead of erroring (see api/lara.ts).
ANTHROPIC_API_KEY=your_claude_api_key
OPENAI_API_KEY=your_openai_api_key

# AI cost governance (all optional — safe defaults ship in code, see api/lara.ts).
# Any of these may be set to 0 to hard-disable that lever immediately, with
# no redeploy needed.
AI_DAILY_TOKEN_BUDGET=5000000
AI_PER_MINUTE_LIMIT=8
AI_KILL_SWITCH=

# Email reminders (Resend) — requires the study_reminders table (migration
# 0015) + CRON_SECRET below. Missing either → the cron no-ops gracefully.
RESEND_API_KEY=your_resend_api_key
REMINDER_FROM=Charles at Scholify <onboarding@resend.dev>
# Required for the Vercel cron to authenticate GET /api/reminders?action=send —
# without it the send path refuses to run (fails closed, not unauthenticated).
CRON_SECRET=your_random_cron_secret

# ── Payments (Stripe — the live billing rail) ──
# All six must be set together, or none at all — /api/health returns 503
# "half_configured" for anything in between (see api/stripe.ts).
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BEGINNER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# ── Payments (Paddle — dormant alternate rail, code paths exist but unused
# in production since the Stripe cutover) ──
VITE_PADDLE_TOKEN=your_paddle_client_token
VITE_PADDLE_BEGINNER_MONTHLY=pri_xxx
VITE_PADDLE_PRO_MONTHLY=pri_xxx
VITE_PADDLE_ANNUAL_PRO=pri_xxx
PADDLE_API_KEY=your_paddle_api_key
PADDLE_ENV=sandbox
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret

# ── Calendar sync (optional) ──
# Google Calendar OAuth — get from https://console.cloud.google.com
# Authorized redirect URI must match VITE_GOOGLE_REDIRECT_URI exactly.
VITE_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
VITE_GOOGLE_REDIRECT_URI=https://scholifyapp.com/auth/google/calendar

# Cal.com — users paste their personal API key from inside the app,
# so no platform-wide secret is required. The env var below is only
# a default for local dev / demos.
VITE_CALCOM_API_KEY=

# ── Analytics (PostHog) ──
# Free account at https://posthog.com → Project Settings → Project API Key.
# Absent = analytics is a no-op (safe for local dev / previews).
VITE_POSTHOG_KEY=phc_xxxxxxxx

# ── App ──
# Leave VITE_API_URL empty — the /api functions are same-origin on Vercel.
VITE_API_URL=
# Read by src/lib/auth.tsx (OAuth/password-reset redirects) and
# api/stripe.ts (checkout success/cancel URLs). NOTE: the real variable name
# is VITE_PUBLIC_SITE_URL, not VITE_APP_URL — set the wrong one and both
# paths silently fall back to the hardcoded production URL, which is wrong
# for any preview/staging deploy.
VITE_PUBLIC_SITE_URL=https://scholifyapp.com
