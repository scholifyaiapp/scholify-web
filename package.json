{
  "name": "scholify-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.api.json",
    "validate:chapters": "tsx --tsconfig tsconfig.app.json scripts/validate-chapters.ts",
    "audit:content": "tsx --tsconfig tsconfig.app.json scripts/audit-content.ts",
    "audit:verification": "tsx --tsconfig tsconfig.app.json scripts/audit-verification.ts",
    "audit:tx-fa2025": "tsx --tsconfig tsconfig.app.json scripts/audit-tx-fa2025.ts",
    "verify:loading": "tsx --tsconfig tsconfig.app.json scripts/verify-dynamic-load.ts",
    "build": "npm run typecheck && npm test && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "posthog-js": "^1.381.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vercel/node": "^5.8.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "sharp": "^0.34.5",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.2.7"
  }
}
